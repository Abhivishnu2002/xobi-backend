# Fastify server configuration
PORT=3001
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Message Central credentials
# Sign up at https://www.messagecentral.com/ to get these
MC_CUSTOMER_ID=your_mc_customer_id_here
MC_PASSWORD=your_mc_password_here
MC_SENDER_ID=SMSIND

# Development Settings
# Set to true to simulate SMS sending without calling real APIs
MOCK_OTP=true
